# Optional backend port (defaults to 3001)
API_PORT=3001

# JSON body limit for API requests (needed for base64 image OCR payloads)
API_JSON_LIMIT=12mb

# Required Postgres connection string
# Example: postgresql://username:password@host:5432/database_name
DATABASE_URL=

# NIH RAG LLM provider
# gemini | groq (default gemini)
NIH_LLM_PROVIDER=groq

# Gemini config (required when NIH_LLM_PROVIDER=gemini)
GEMINI_API_KEY=
NIH_LLM_MODEL=gemini-2.0-flash

# Groq config (required when NIH_LLM_PROVIDER=groq)
GROQ_API_KEY=
NIH_GROQ_MODEL=llama-3.1-8b-instant

# Optional NIH RAG tuning
NIH_TOP_K=6
NIH_MAX_CONTEXT_CHARS=12000
NIH_MAX_QPS_PER_USER=1
NIH_MAX_REQ_PER_HOUR=30

# Breath OCR (Mistral, JPG/PNG only)
MISTRAL_API_KEY=
BREATH_OCR_MODEL=mistral-ocr-latest
BREATH_OCR_TIMEOUT_MS=20000
BREATH_OCR_MAX_IMAGE_MB=8
BREATH_OCR_MAX_REQ_PER_HOUR=40

# Production flags (set on Render)
NODE_ENV=production
VITE_BASE_URL=/
